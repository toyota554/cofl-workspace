# ─────────────────────────────────────────────────────────────
# COFL Environment Configuration
# Copy to .env and fill in your values before running:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Ollama / LLM ──────────────────────────────────────────────
# Pareto-optimal model for CPU-only inference (paper §4.3)
OLLAMA_MODEL=llama3:8b-instruct-q4_K_M

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=cofldb
POSTGRES_USER=cofl
POSTGRES_PASSWORD=coflsecret          # CHANGE THIS in production

# ── n8n ──────────────────────────────────────────────────────
N8N_HOST=localhost                    # Set to your server IP or domain
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cofl2026      # CHANGE THIS in production

# ── FastAPI Gateway ───────────────────────────────────────────
# Sentiment score threshold (paper §3.4 — triggers /generate below this)
SENTIMENT_THRESHOLD=0.35

# LLM inference temperature (paper §3.5 — 0.1 for classification determinism)
LLM_TEMPERATURE=0.1

# Maximum words in generated customer service response (paper §3.5)
GENERATE_MAX_WORDS=150
